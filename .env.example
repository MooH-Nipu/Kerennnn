# Copy this file to .env.local and fill in your key
# In Vercel dashboard: Settings → Environment Variables → add VT_API_KEY
VT_API_KEY=your_virustotal_api_key_here

# URLhaus (abuse.ch) API key (sent as "Auth-Key" header)
# Can set either ABUSECH_API_KEY or URLHAUS_API_KEY
ABUSECH_API_KEY=your_urlhaus_auth_key_here

# Trust multipliers for confidence weighting (default 1 = equal share)
# Example: TRUST_OTX=2 makes OTX twice as influential as others
TRUST_VT=1
TRUST_OTX=1
TRUST_ABUSEIPDB=1
TRUST_ABUSECH=1
