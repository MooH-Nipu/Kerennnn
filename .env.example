# Copy to .env.local for local dev (vercel dev). In Vercel: Settings → Environment Variables.

# ── VirusTotal (required for /api/vt and correlation) ──
# Optional rotation: VT_API_KEY_2 … VT_API_KEY_10
VT_API_KEY=your_virustotal_api_key_here

# ── Correlation (/api/correlate) — optional; sources skip if unset ──
# AbuseIPDB (IP only)
# Optional rotation: ABUSEIPDB_API_KEY_2 … ABUSEIPDB_API_KEY_10 (rotates on 429 quota exhaustion)
ABUSEIPDB_API_KEY=
# AlienVault OTX (all types)
OTX_API_KEY=
# abuse.ch URLhaus (IP + domain; either name works in code)
ABUSECH_API_KEY=
URLHAUS_API_KEY=
# GreyNoise (IP only)
GREYNOISE_API_KEY=
# URLScan.io (domain only)
URLSCAN_API_KEY=
# Shodan (IP only; context source — exposed ports / known CVEs)
SHODAN_API_KEY=
# Pulsedive (all types)
PULSEDIVE_API_KEY=
# Keyless (no key needed): abuse.ch (IP/domain) & MalwareBazaar (hash only)

# RDAP/GeoIP enrichment (/api/correlate). RDAP (rdap.org) needs no key.
# GeoIP uses ipinfo.io when IPINFO_TOKEN is set, else keyless ipwho.is.
IPINFO_TOKEN=

# Trust multipliers for confidence weighting (default 1; multiplies each source's base weight)
TRUST_VT=1
TRUST_OTX=1
TRUST_ABUSEIPDB=1
TRUST_ABUSECH=1
TRUST_GREYNOISE=1
TRUST_URLSCAN=1
TRUST_PULSEDIVE=1
# Keyless abuse.ch sources (Shodan has no trust factor — context-only)
TRUST_MALWAREBAZAAR=1

# ── Analyst tools (Initiative 3) ──
# CVE / NVD lookup (/api/cve). Key is OPTIONAL — only raises the NVD rate limit.
NVD_API_KEY=
# MITRE ATT&CK (/api/attack), Passive DNS (/api/passive-dns), crt.sh (/api/crt) are keyless.

# ── MALICIOUS alert webhook — /api/correlate fires when confidence ≥ 70 ──
# Slack / Teams / Discord incoming webhook (payload shape auto-detected from the URL),
# or any endpoint that accepts a generic JSON POST. Leave unset to disable alerts.
ALERT_WEBHOOK_URL=
# Optional: public base URL of this app, used to deep-link /result/:id in the alert.
APP_BASE_URL=

# ── PAC Filter tab — database (Supabase) + optional API password ──
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# If set, /api/scan-merger requires header X-Merger-Password (PAC Filter UI does not collect it; leave unset for browser use).
MERGER_API_PASSWORD=

# ── App login (single password) ──
# If set, the web UI will require login and protected API endpoints will return 401 without a valid session cookie.
APP_PASSWORD=
# Random secret for signing the HttpOnly cookie session.
APP_AUTH_SECRET=
# Force Secure cookies in dev if needed (default: true in production).
COOKIE_SECURE=
# Login brute-force lockout per (username, IP). Defaults: 10 attempts / 15 min window.
LOGIN_MAX_ATTEMPTS=10
LOGIN_WINDOW_MINUTES=15
